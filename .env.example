# .env.example ────────────────────────────────────────────────────────────────
# MAAVIS TALENT HUB – Environment Variables Template
# Copy to .env and fill in REAL values. Never commit .env!
# ──────────────────────────────────────────────────────────────────────────────

# Discord – Main Bot (main-bot.py)
DISCORD_TOKEN_MAIN=your.main.bot.token.here
DISCORD_GUILD_ID=123456789012345678          # Your server ID (for faster slash command registration)
DISCORD_OWNER_ID=your.discord.user.id.here   # Restrict sensitive commands to this user

# Discord – Backup Bot (backup-bot.py) – optional if using separate token
# DISCORD_TOKEN_BACKUP=your.backup.bot.token.here

# Website / Server (Vite + server.ts)
PORT=3000                                    # Internal port for the website
NODE_ENV=development                         # or production
# HOST=0.0.0.0                               # uncomment if external access needed

# Cloudflare Tunnel (only if using named tunnel instead of quick tunnel)
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_from_dashboard
# CLOUDFLARE_TUNNEL_NAME=maavis-tunnel

# Optional: if send-tunnel-url.sh needs to notify somewhere
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...   # for sending tunnel URL

# Optional: Email (already in original)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Optional: Data / Database (if used later)
DATA_DIR=./data

# Optional: Git / Updater (if auto-update.sh needs private repo access)
# GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
