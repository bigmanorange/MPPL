# MAAVIS TALENT HUB - .env.example
# Copy to .env and fill in real values. Do NOT commit .env!

# Discord - Main Bot
DISCORD_TOKEN_MAIN=your.main.bot.token.here
DISCORD_GUILD_ID=123456789012345678        # Your Discord server ID (for fast command sync)
DISCORD_OWNER_ID=your.discord.user.id.here  # Your user ID (restricts maavis_* commands)

# Discord - Backup Bot (optional - can be same token or separate app)
BACKUP_TOKEN=your.backup.bot.token.here

# Website / Server
PORT=3000
NODE_ENV=development                        # change to production when ready

# SMTP Configuration (for emails/notifications if used)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Optional - if auto-update.sh needs GitHub auth for private repo
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
